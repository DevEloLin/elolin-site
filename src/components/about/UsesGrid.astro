---
import { langColor } from "@/lib/languages";
type Props = { items: string[] };
const { items } = Astro.props;
---
<div class="flex flex-wrap gap-2">
  {items.map((i) => (
    <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-bg-1 border border-white/10 text-body-sm">
      <span class="inline-block w-2 h-2 rounded-full" style={`background:${langColor(i)}`}></span>
      {i}
    </span>
  ))}
</div>
