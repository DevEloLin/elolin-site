---
type Props = { size?: number; class?: string };
const { size = 32, class: cls = "" } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 64 64" class={cls} role="img" aria-labelledby="hex-logo-title">
  <title id="hex-logo-title">EloLin</title>
  <defs>
    <linearGradient id="hex-grad" x1="0" y1="0" x2="64" y2="64" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#7C3AED"/>
      <stop offset="1" stop-color="#3B82F6"/>
    </linearGradient>
  </defs>
  <polygon points="32,4 58,18 58,46 32,60 6,46 6,18" fill="url(#hex-grad)"/>
  <path d="M22 20 H42 V26 H28 V30 H40 V36 H28 V40 H42 V46 H22 Z" fill="#0A0A0F" opacity="0.92"/>
</svg>
