---
import { cn } from "@/lib/cn";
type Props = { class?: string; interactive?: boolean; as?: "div" | "a"; href?: string };
const { class: cls = "", interactive = false, as: Tag = "div", href, ...attributes } = Astro.props as Props & Record<string, unknown>;
const base = "relative overflow-hidden rounded-[1.45rem] border border-white/[0.09] bg-[linear-gradient(145deg,rgba(28,28,38,0.82),rgba(10,10,17,0.78))] p-6 shadow-[0_18px_60px_rgba(0,0,0,0.2)] backdrop-blur-xl before:absolute before:inset-0 before:pointer-events-none before:bg-[linear-gradient(115deg,rgba(255,255,255,0.07),transparent_28%)]";
const inter = interactive
  ? "transition-all duration-300 ease-out hover:-translate-y-1 hover:border-blue-200/25 hover:shadow-[0_24px_80px_rgba(0,0,0,0.36),0_0_55px_rgba(59,130,246,0.12)]"
  : "";
---
<Tag class={cn(base, inter, cls)} {...attributes} {...(href ? { href } : {})}>
  <slot />
</Tag>
