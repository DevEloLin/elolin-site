---
import { localizePath, type Locale } from "@/lib/i18n";
import { t } from "@/lib/i18n";
type Props = { current: Locale; path: string };
const { current, path } = Astro.props;
const other: Locale = current === "en" ? "zh" : "en";
const href = localizePath(path, other);
---
<a href={href}
   class="text-body-sm text-fg-1 hover:text-fg-0 transition px-2 py-1 rounded-md hover:bg-bg-1"
   aria-label={`Switch language to ${other}`}>
  {t("common.switchLang", current)}
</a>
