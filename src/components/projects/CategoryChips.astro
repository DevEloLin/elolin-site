---
import { t, type Locale } from "@/lib/i18n";
type Props = { locale: Locale; active: string };
const { locale, active } = Astro.props;
const chips = ["all", "ai", "product", "tool", "skill", "site"] as const;
---
<div class="flex flex-wrap gap-2 rounded-[1.25rem] border border-white/[0.08] bg-white/[0.025] p-2" role="tablist" aria-label="Project categories">
  {chips.map((c) => {
    const isAi = c === "ai";
    const isActive = active === c;
    const base = "rounded-xl border px-4 py-2 text-caption uppercase transition duration-200";
    const aiActive  = "bg-grad-brand text-white border-transparent shadow-glow-brand";
    const aiIdle    = "bg-grad-brand/30 text-white border-transparent";
    const normalActive = "bg-white/[0.12] text-fg-0 border-white/20";
    const normalIdle   = "border-transparent text-fg-1 hover:bg-white/[0.06] hover:text-fg-0";
    const styles = isAi
      ? (isActive ? aiActive : aiIdle)
      : (isActive ? normalActive : normalIdle);
    return (
      <button data-cat={c} class={`chip-btn ${base} ${styles}`} aria-selected={isActive}>
        {isAi && "✦ "}{t(`projects.chips.${c}`, locale)}
      </button>
    );
  })}
</div>
