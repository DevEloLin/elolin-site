---
import GlassCard from "@/components/ui/GlassCard.astro";
import Button from "@/components/ui/Button.astro";
import AiBadge from "@/components/ui/AiBadge.astro";
import VisualCardMedia from "@/components/ui/VisualCardMedia.astro";
import { ExternalLink, Github } from "lucide-astro";
import projects from "@/data/projects.json";
import { projectDescription, t, type Locale } from "@/lib/i18n";
import type { Project } from "@/lib/github";
import type { ProductEntry } from "@/lib/site";

type Props = { product: ProductEntry; locale: Locale };

const { product, locale } = Astro.props;
const all = projects as Project[];
const repo = product.repo ? all.find((p) => p.slug === product.repo) : undefined;
const isAi = repo?.tags.includes("ai") ?? false;

// Description priority:
//   1. product.tagline (always present on ProductEntry) — single source of truth
//   2. projectDescription(repo, ...) — legacy GitHub-based fallback only if tagline missing
//      (kept as defensive fallback; current shape guarantees tagline exists)
const desc =
  product.tagline?.[locale] ??
  (repo ? projectDescription(repo.slug, repo.description, locale) : "");
---
<GlassCard interactive class="group h-full overflow-hidden p-0">
  <div class="flex h-full flex-col">
    <VisualCardMedia
      seed={product.slug}
      title={product.name}
      subtitle={product.tagline[locale]}
      kind="product"
      {...(product.coverImage ? { image: product.coverImage } : {})}
      class="min-h-[17rem] rounded-none border-0 sm:min-h-[19rem]"
    />
    <div class="relative z-10 flex flex-1 flex-col p-6 sm:p-7">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="section-eyebrow">Live product</p>
          <h2 class="mt-4 text-h2 font-semibold tracking-[-0.04em]">{product.name}</h2>
          <p class="mt-3 text-fg-1 text-body leading-relaxed">{desc}</p>
        </div>
        {isAi && <AiBadge />}
      </div>
      <div class="mt-6 flex flex-wrap gap-2">
        {product.tags.map((tag) => (
          <span class="px-3 py-1 rounded-full text-caption text-fg-1 bg-bg-1 border border-white/10">{tag}</span>
        ))}
      </div>
      <div class="mt-auto flex flex-wrap items-center gap-3 pt-8">
        <Button href={product.url} external>
          {t("products.links.site", locale)} <ExternalLink size={16} />
        </Button>
        {repo && (
          <Button href={repo.url} variant="ghost" external>
            <Github size={16} /> {t("products.links.github", locale)}
          </Button>
        )}
        {product.extraLinks?.map((l) => (
          <Button href={l.href} variant="ghost" external>{l.label}</Button>
        ))}
      </div>
    </div>
  </div>
</GlassCard>
