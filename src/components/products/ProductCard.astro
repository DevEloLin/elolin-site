---
import GlassCard from "@/components/ui/GlassCard.astro";
import Button from "@/components/ui/Button.astro";
import AiBadge from "@/components/ui/AiBadge.astro";
import { ExternalLink, Github } from "lucide-astro";
import projects from "@/data/projects.json";
import { projectDescription, t, type Locale } from "@/lib/i18n";
import type { Project } from "@/lib/github";

type ProductMeta = {
  slug: string;
  name: string;
  repo: string;
  homepage: string;
  tags: readonly string[];
  extraLinks: readonly { label: string; href: string }[];
};

type Props = { product: ProductMeta; locale: Locale };

const { product, locale } = Astro.props;
const all = projects as Project[];
const repo = all.find((p) => p.slug === product.repo);
const isAi = repo?.tags.includes("ai") ?? true;
const desc = repo ? projectDescription(repo.slug, repo.description, locale) : "";
---
<GlassCard>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-h2 font-semibold">{product.name}</h2>
      <p class="mt-3 text-fg-1 text-body-lg max-w-2xl">{desc}</p>
    </div>
    {isAi && <AiBadge />}
  </div>
  <div class="mt-6 flex flex-wrap gap-2">
    {product.tags.map((tag) => (
      <span class="px-3 py-1 rounded-full text-caption text-fg-1 bg-bg-1 border border-white/10">{tag}</span>
    ))}
  </div>
  <div class="mt-8 flex flex-wrap items-center gap-3">
    <Button href={product.homepage} external>
      {t("products.links.site", locale)} <ExternalLink size={16} />
    </Button>
    {repo && (
      <Button href={repo.url} variant="ghost" external>
        <Github size={16} /> {t("products.links.github", locale)}
      </Button>
    )}
    {product.extraLinks.map((l) => (
      <Button href={l.href} variant="ghost" external>{l.label}</Button>
    ))}
  </div>
</GlassCard>
