---
import GlassCard from "@/components/ui/GlassCard.astro";
type Props = { icon: any; label: string; value: string; href: string; copy?: boolean };
const { label, value, href, copy = false } = Astro.props as any;
const Icon = (Astro.props as any).icon;
---
<GlassCard interactive>
  <div class="flex items-center gap-3">
    <span class="grid h-10 w-10 place-items-center rounded-xl border border-blue-200/15 bg-blue-400/[0.08] text-blue-100"><Icon size={18} /></span>
    <p class="section-eyebrow">{label}</p>
  </div>
  <p class="mt-5 text-body font-medium break-all">{value}</p>
  <div class="mt-6 flex items-center gap-3 border-t border-white/[0.08] pt-4 text-body-sm">
    <a href={href} target={href.startsWith("mailto") ? "_self" : "_blank"} rel="noopener" class="text-blue-100 transition hover:text-white">↗ Open</a>
    {copy && (
      <button class="copy-btn text-fg-1 hover:text-fg-0" data-copy={value}>Copy</button>
    )}
  </div>
</GlassCard>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((b) => {
    b.addEventListener("click", () => {
      navigator.clipboard.writeText(b.dataset.copy ?? "").then(() => {
        const orig = b.textContent;
        b.textContent = "Copied";
        setTimeout(() => (b.textContent = orig), 1200);
      });
    });
  });
</script>
