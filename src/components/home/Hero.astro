---
import Button from "@/components/ui/Button.astro";
import { localizePath, t, type Locale } from "@/lib/i18n";
import { ArrowRight, ArrowUpRight } from "lucide-astro";

type Props = { locale: Locale };
const { locale } = Astro.props;

const projectsHref = localizePath("/products", locale);
const testHiveHref = "https://testhive.elolin.com";
const featuredProducts = [
  {
    href: testHiveHref,
    image: "https://testhive.elolin.com/opengraph-image.png",
    eyebrow: t("home.hero.featuredEyebrow", locale),
    name: t("home.hero.featuredName", locale),
    tagline: t("home.hero.featuredTagline", locale),
    description: t("home.hero.featuredDescription", locale),
  },
  {
    href: "https://kinmate.elolin.com",
    image: "https://develolin.github.io/kinmate-site/icon-512.png",
    eyebrow: t("home.hero.kinmateEyebrow", locale),
    name: t("home.hero.kinmateName", locale),
    tagline: t("home.hero.kinmateTagline", locale),
    description: t("home.hero.kinmateDescription", locale),
  },
];
const proof =
  locale === "zh"
    ? ["7 个已上线产品", "一个账号通行", "持续公开迭代"]
    : [
        "7 products in the wild",
        "One account across the suite",
        "Built in public",
      ];
---

<section class="hero-shell relative isolate overflow-hidden pt-16" data-hero>
  <div class="absolute inset-0 hero-grid" aria-hidden="true"></div>

  <div class="hero-stage">
    <video
      class="hero-video"
      src="/media/elolin-hero.mp4"
      poster="/media/elolin-hero-poster.jpg"
      autoplay
      muted
      loop
      playsinline
      data-bg-video
      preload="metadata"
      aria-hidden="true"></video>
    <div class="hero-video-overlay" aria-hidden="true"></div>

    <div class="hero-content-shell">
      <div class="hero-content" data-reveal>
        <p class="hero-kicker">
          <span class="hero-kicker-dot" aria-hidden="true"></span>
          {locale === "zh" ? "独立产品工作室" : "Independent product studio"}
        </p>

        <h1
          class="hero-title mt-6 text-display-2 md:text-display-1 font-semibold leading-[0.94] tracking-[-0.055em] text-white"
        >
          {t("home.hero.title", locale)}
        </h1>

        <p
          class="hero-subtitle mt-6 max-w-2xl text-body-lg md:text-h3 text-fg-1"
        >
          {t("home.hero.subtitle", locale)}
        </p>

        <div class="mt-9 flex flex-wrap gap-3">
          <Button href={projectsHref}>
            {t("home.hero.ctaPrimary", locale)}
            <ArrowRight size={18} />
          </Button>
          <Button href={testHiveHref} variant="ghost" external>
            {t("home.hero.ctaSecondary", locale)}
            <ArrowUpRight size={17} />
          </Button>
        </div>

        <ul
          class="hero-proof mt-10"
          aria-label={locale === "zh"
            ? "EloLin 产品概览"
            : "EloLin product overview"}
        >
          {proof.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>

    <div class="hero-launches" data-motion-section aria-label={locale === "zh" ? "已上线产品" : "Live products"}>
      {featuredProducts.map((product) => (
        <a
          href={product.href}
          target="_blank"
          rel="noopener"
          class="hero-featured group"
          data-motion-item
          aria-label={`${product.eyebrow}: ${product.name}`}
        >
          <div class="hero-featured-media" aria-hidden="true">
            <img src={product.image} alt="" loading="eager" decoding="async" />
            <span class="hero-featured-scan"></span>
            <span class="hero-featured-orbit hero-featured-orbit--one"></span>
            <span class="hero-featured-orbit hero-featured-orbit--two"></span>
          </div>
          <div class="hero-featured-glow" aria-hidden="true"></div>
          <div class="hero-featured-content">
            <span class="hero-featured-eyebrow">
              <span class="hero-featured-dot" aria-hidden="true"></span>
              {product.eyebrow}
            </span>
            <div class="hero-featured-row">
              <div>
                <p class="hero-featured-name">{product.name}</p>
                <p class="hero-featured-tagline">{product.tagline}</p>
              </div>
              <ArrowUpRight
                class="hero-featured-arrow"
                size={20}
                aria-hidden="true"
              />
            </div>
            <p class="hero-featured-desc">{product.description}</p>
          </div>
        </a>
      ))}
    </div>

    <p class="hero-index" aria-hidden="true">01 / 07</p>
  </div>
</section>

<script>
  const bgVideo = document.querySelector<HTMLVideoElement>("[data-bg-video]");

  if (bgVideo) {
    const slowRate = 0.45;
    const syncRate = () => {
      bgVideo.playbackRate = slowRate;
      bgVideo.defaultPlaybackRate = slowRate;
    };

    syncRate();
    bgVideo.addEventListener("loadedmetadata", syncRate);
    bgVideo.addEventListener("play", syncRate);
  }
</script>

<style>
  .hero-shell {
    background: #05060a;
  }

  .hero-grid {
    z-index: 1;
    opacity: 0.24;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.045) 1px, transparent 1px);
    background-size: 52px 52px;
    mask-image: linear-gradient(
      90deg,
      #000 0%,
      rgba(0, 0, 0, 0.62) 48%,
      transparent 88%
    );
    pointer-events: none;
  }

  .hero-stage {
    position: relative;
    min-height: calc(100svh - 4rem);
    overflow: hidden;
    background: #05060a;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 56% 50%;
    transform: scale(1.07);
    filter: saturate(0.9) contrast(1.14) brightness(0.78);
  }

  .hero-video-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(
        circle at 70% 48%,
        rgba(96, 165, 250, 0.22),
        transparent 24%
      ),
      linear-gradient(
        90deg,
        rgba(3, 6, 15, 0.97) 0%,
        rgba(3, 6, 15, 0.86) 34%,
        rgba(3, 6, 15, 0.35) 65%,
        rgba(3, 6, 15, 0.52) 100%
      ),
      linear-gradient(
        180deg,
        rgba(3, 6, 15, 0.25),
        transparent 30%,
        rgba(3, 6, 15, 0.7) 100%
      );
  }

  .hero-content-shell {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    min-height: calc(100svh - 4rem);
    width: min(100% - 3rem, 76rem);
    margin: 0 auto;
    padding: clamp(4rem, 9vw, 7.25rem) 0 clamp(4rem, 8vw, 6rem);
  }

  .hero-content {
    max-width: 47rem;
    text-shadow: 0 2px 28px rgba(0, 0, 0, 0.52);
  }

  .hero-kicker,
  .hero-featured-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: rgba(219, 234, 254, 0.88);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .hero-kicker-dot,
  .hero-featured-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 9999px;
    background: #60a5fa;
    box-shadow:
      0 0 0 5px rgba(96, 165, 250, 0.12),
      0 0 18px rgba(96, 165, 250, 0.96);
  }

  .hero-title {
    max-width: 11ch;
  }

  .hero-subtitle {
    text-wrap: balance;
  }

  .hero-proof {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem 1.25rem;
    padding: 0;
    margin-bottom: 0;
    list-style: none;
    color: rgba(226, 232, 240, 0.64);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  .hero-proof li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-proof li::before {
    width: 3px;
    height: 3px;
    border-radius: 9999px;
    background: rgba(147, 197, 253, 0.9);
    content: "";
  }

  .hero-launches {
    position: absolute;
    z-index: 4;
    right: max(1.5rem, calc((100vw - 76rem) / 2));
    bottom: clamp(1.5rem, 4vw, 3.5rem);
    width: min(24rem, calc(100vw - 3rem));
    display: grid;
    gap: 0.8rem;
  }

  .hero-featured {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(191, 219, 254, 0.22);
    border-radius: 1.25rem;
    background: linear-gradient(
      135deg,
      rgba(13, 20, 38, 0.88),
      rgba(5, 8, 17, 0.92)
    );
    color: inherit;
    text-decoration: none;
    backdrop-filter: blur(18px);
    box-shadow:
      0 18px 60px rgba(0, 0, 0, 0.36),
      0 0 0 1px rgba(255, 255, 255, 0.035) inset;
    transition:
      transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 220ms ease,
      box-shadow 220ms ease;
  }

  .hero-featured:hover,
  .hero-featured:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(147, 197, 253, 0.58);
    box-shadow:
      0 26px 72px rgba(0, 0, 0, 0.46),
      0 0 48px rgba(59, 130, 246, 0.18);
    outline: none;
  }

  .hero-featured-glow {
    position: absolute;
    top: -9rem;
    right: -8rem;
    width: 18rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: rgba(96, 165, 250, 0.34);
    filter: blur(58px);
    transition: opacity 220ms ease;
  }

  .hero-featured-media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-featured-media::after {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(5, 8, 17, 0.96) 0%, rgba(5, 8, 17, 0.86) 45%, rgba(5, 8, 17, 0.34) 100%),
      linear-gradient(0deg, rgba(5, 8, 17, 0.88), transparent 65%);
    content: "";
  }

  .hero-featured-media img {
    position: absolute;
    top: -12%;
    right: -8%;
    width: 62%;
    height: 124%;
    object-fit: cover;
    filter: saturate(0.9) contrast(1.12) brightness(0.72);
    opacity: 0.76;
    transform: scale(1.08) rotate(-3deg);
    transition: transform 700ms cubic-bezier(0.16, 1, 0.3, 1), filter 500ms ease, opacity 500ms ease;
  }

  .hero-featured-scan {
    position: absolute;
    z-index: 1;
    top: -20%;
    right: 5%;
    width: 1px;
    height: 140%;
    background: linear-gradient(180deg, transparent, rgba(191, 219, 254, 0.9), transparent);
    box-shadow: 0 0 22px rgba(96, 165, 250, 0.72);
    opacity: 0.72;
    transform: rotate(18deg);
    animation: featured-scan 6s ease-in-out infinite;
  }

  .hero-featured-orbit {
    position: absolute;
    z-index: 1;
    border: 1px solid rgba(191, 219, 254, 0.32);
    border-radius: 999px;
    box-shadow: 0 0 26px rgba(96, 165, 250, 0.16);
    pointer-events: none;
  }

  .hero-featured-orbit--one {
    top: -5rem;
    right: -4rem;
    width: 12rem;
    aspect-ratio: 1;
    animation: featured-orbit-one 12s linear infinite;
  }

  .hero-featured-orbit--two {
    right: 14%;
    bottom: -6rem;
    width: 9rem;
    aspect-ratio: 1;
    border-color: rgba(216, 180, 254, 0.26);
    animation: featured-orbit-two 16s linear infinite reverse;
  }

  .hero-featured:hover .hero-featured-glow {
    opacity: 1;
  }

  .hero-featured:hover .hero-featured-media img,
  .hero-featured:focus-visible .hero-featured-media img {
    filter: saturate(1.08) contrast(1.04) brightness(0.92);
    opacity: 0.94;
    transform: scale(1.16) rotate(0deg) translateX(-0.4rem);
  }

  .hero-featured-content {
    position: relative;
    padding: 1.3rem 1.35rem 1.35rem;
  }

  .hero-featured-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.85rem;
  }

  .hero-featured-name {
    color: white;
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .hero-featured-tagline {
    margin-top: 0.45rem;
    color: rgba(226, 232, 240, 0.86);
    font-size: 0.85rem;
    line-height: 1.4;
  }

  .hero-featured-arrow {
    flex: none;
    color: #bfdbfe;
    transition: transform 220ms ease;
  }

  .hero-featured:hover .hero-featured-arrow {
    transform: translate(3px, -3px);
  }

  .hero-featured-desc {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(203, 213, 225, 0.72);
    font-size: 0.78rem;
    line-height: 1.55;
  }

  @keyframes featured-scan {
    0%, 100% { translate: 0 -10%; opacity: 0.18; }
    48% { opacity: 0.8; }
    50% { translate: -5rem 58%; opacity: 0.8; }
    52% { opacity: 0.18; }
  }

  @keyframes featured-orbit-one { to { transform: rotate(360deg); } }
  @keyframes featured-orbit-two { to { transform: rotate(360deg); } }

  .hero-index {
    position: absolute;
    z-index: 3;
    right: max(1.5rem, calc((100vw - 76rem) / 2));
    top: 2rem;
    margin: 0;
    color: rgba(255, 255, 255, 0.44);
    font-family: "Geist Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
  }

  @media (max-width: 900px) {
    .hero-stage,
    .hero-content-shell {
      min-height: auto;
    }

    .hero-content-shell {
      padding-bottom: 1.5rem;
    }

    .hero-launches {
      position: relative;
      right: auto;
      bottom: auto;
      width: min(100% - 3rem, 44rem);
      margin: 0 auto 2.5rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-video {
      object-position: 65% 50%;
    }
    .hero-video-overlay {
      background:
        linear-gradient(
          90deg,
          rgba(3, 6, 15, 0.94) 0%,
          rgba(3, 6, 15, 0.76) 58%,
          rgba(3, 6, 15, 0.45) 100%
        ),
        linear-gradient(
          180deg,
          rgba(3, 6, 15, 0.2),
          transparent 40%,
          rgba(3, 6, 15, 0.68) 100%
        );
    }
  }

  @media (max-width: 640px) {
    .hero-content-shell {
      align-items: flex-start;
      min-height: auto;
      padding-top: 4.25rem;
      padding-bottom: 1.5rem;
    }

    .hero-stage {
      min-height: calc(100svh - 4rem);
    }
    .hero-video {
      object-position: 64% 50%;
    }
    .hero-video-overlay {
      background:
        linear-gradient(90deg, rgba(3, 6, 15, 0.94), rgba(3, 6, 15, 0.52)),
        linear-gradient(180deg, rgba(3, 6, 15, 0.1), rgba(3, 6, 15, 0.8) 100%);
    }

    .hero-title {
      max-width: 10ch;
    }
    .hero-proof {
      font-size: 0.69rem;
      gap: 0.5rem 0.75rem;
    }

    .hero-launches {
      position: relative;
      right: auto;
      bottom: auto;
      width: min(100% - 3rem, 24rem);
      margin-bottom: 1.25rem;
      grid-template-columns: 1fr;
    }

    .hero-index {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-featured {
      transition: none;
    }

    .hero-featured-scan,
    .hero-featured-orbit {
      animation: none;
    }
  }
</style>
