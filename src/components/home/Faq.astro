---
import { type Locale } from "@/lib/i18n";
type Props = { locale: Locale };
const { locale } = Astro.props;

const QA = locale === "zh" ? [
  { q: "EloLin 是什么?",
    a: "EloLin 是一家一人独立工作室,旗下包含 8 个产品(EvoClaw · PhotoAI · KinMate · TestHive · EloGames · Zivoe · Domains · mv3migrate),覆盖 AI agent · AI 图像 · 家庭健康 · 众测 · 游戏 · 工业设计 · 域名托管 · 开发者工具,并由 Accounts 单点登录打通。所有产品由 Wei Li 独自打造和运营。" },
  { q: "EloLin 的产品收费吗?",
    a: "大部分产品免费或有免费额度:Accounts 单点登录、Domains 子域名托管、EloGames 免费玩、TestHive 免费门槛和 Karma 经济、EvoClaw 开源、KinMate 基础功能、mv3migrate 免费扫描都免费。PhotoAI 按次计费(有 $1 起步包,失败自动退),Zivoe 是自带 key 的付费桌面工具。" },
  { q: "EloLin 的产品之间是怎么打通的?",
    a: "所有产品共用 EloLin Accounts(accounts.elolin.com)的单点登录 · 注册一次即可访问全部 SaaS 产品 · session 自动跨 .elolin.com 子域名同步。mv3migrate 是本地 CLI 工具 · 不需要登录。" },
  { q: "EloLin 开源吗?",
    a: "默认开源。EvoClaw 和大部分项目源码都在 https://github.com/DevEloLin 公开。商业产品的客户端代码也尽量开源。" },
  { q: "EloLin 是一个人做的吗?",
    a: "是。EloLin 是一家一人公司(One person. Many products.)· 创始人是 Wei Li(@DevEloLin)· 所有产品的设计 · 开发 · 运营都由一个人完成。" },
] : [
  { q: "What is EloLin?",
    a: "EloLin is a one-person indie studio shipping eight products: EvoClaw (AI agent), PhotoAI (AI images), KinMate (family health), TestHive (crowd-testing), EloGames (games), Zivoe (industrial design), EloLin Domains (hosting), and mv3migrate (Chrome extension migration CLI) — all tied together by Accounts SSO. Everything is built and operated solo by Wei Li." },
  { q: "Are EloLin products free?",
    a: "Most are free or have a free tier — Accounts SSO, a free Domains sub-domain, EloGames, open-source EvoClaw, KinMate's free tier, and mv3migrate's free scans. PhotoAI is pay-per-use (with a $1 starter pack, auto-refunded on failure), and Zivoe is a paid bring-your-own-key desktop tool." },
  { q: "How are the EloLin products connected?",
    a: "All SaaS products share EloLin Accounts SSO at accounts.elolin.com — sign up once and you're signed into every product. Session cookies are scoped to .elolin.com so the experience is seamless across sub-domains. mv3migrate is a local-first CLI and doesn't require login." },
  { q: "Is EloLin open-source?",
    a: "Open-source by default. EvoClaw and most projects live at https://github.com/DevEloLin. Even commercial product front-ends are open where it makes sense." },
  { q: "Is EloLin really run by one person?",
    a: "Yes — One person. Many products. Founder Wei Li (@DevEloLin) handles design, engineering, and operations for the whole product family." },
];
---
<section class="py-24 sm:py-32" data-reveal>
  <div class="faq-stage container mx-auto px-6 max-w-5xl" data-motion-section>
    <header class="faq-stage__header" data-motion-item>
      <p class="section-eyebrow">FAQ</p>
      <h2 class="section-title">
        {locale === "zh" ? "常见问题" : "Common questions"}
      </h2>
      <p>{locale === "zh" ? "关于产品、开放源代码与独立运营的直接回答。" : "Direct answers about the products, the open work, and the solo studio behind it."}</p>
    </header>
    <dl class="faq-stage__list" data-motion-item>
      {QA.map((it, index) => (
        <details class="faq-stage__item group">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium tracking-[-0.02em]">
            <dt><span>{String(index + 1).padStart(2, "0")}</span>{it.q}</dt>
            <span class="faq-stage__toggle">+</span>
          </summary>
          <dd>{it.a}</dd>
        </details>
      ))}
    </dl>
  </div>
</section>
<style>
  .faq-stage { display: grid; grid-template-columns: minmax(14rem, 0.6fr) minmax(0, 1.4fr); gap: clamp(2rem, 7vw, 7rem); align-items: start; }
  .faq-stage__header { position: sticky; top: 7rem; }
  .faq-stage__header p:last-child { max-width: 17rem; margin-top: 1rem; color: var(--fg-2); font-size: 0.88rem; line-height: 1.6; }
  .faq-stage__list { margin: 0; border-top: 1px solid rgba(191,219,254,0.2); }
  .faq-stage__item { border-bottom: 1px solid rgba(255,255,255,0.1); transition: background 200ms ease; }
  .faq-stage__item:hover { background: linear-gradient(90deg, rgba(59,130,246,0.06), transparent 62%); }
  .faq-stage__item summary { padding: 1.3rem 0; color: var(--fg-0); font-size: clamp(1rem, 1.4vw, 1.12rem); }
  .faq-stage__item summary::-webkit-details-marker { display: none; }
  .faq-stage__item dt { display: flex; align-items: baseline; gap: 1rem; }
  .faq-stage__item dt span { flex: none; color: rgba(147,197,253,0.68); font-family: "Geist Mono", monospace; font-size: 0.67rem; font-weight: 500; letter-spacing: 0.1em; }
  .faq-stage__toggle { display: grid; flex: none; width: 1.75rem; height: 1.75rem; place-items: center; border: 1px solid rgba(191,219,254,0.25); border-radius: 50%; color: var(--fg-1); font-size: 1.15rem; font-weight: 300; line-height: 1; transition: transform 240ms ease, background 240ms ease, color 240ms ease; }
  .faq-stage__item[open] .faq-stage__toggle { background: #dbeafe; color: #07111f; transform: rotate(45deg); }
  .faq-stage__item dd { max-width: 43rem; margin: 0; padding: 0 3rem 1.5rem 2rem; color: var(--fg-1); font-size: 0.92rem; line-height: 1.7; }
  @media (max-width: 760px) { .faq-stage { grid-template-columns: 1fr; gap: 2rem; } .faq-stage__header { position: static; } .faq-stage__item dd { padding-right: 0.5rem; } }
</style>
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: QA.map(it => ({
    "@type": "Question",
    name: it.q,
    acceptedAnswer: { "@type": "Answer", text: it.a },
  })),
})} />
