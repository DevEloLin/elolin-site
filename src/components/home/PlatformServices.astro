---
import GlassCard from "@/components/ui/GlassCard.astro";
import VisualCardMedia from "@/components/ui/VisualCardMedia.astro";
import { ArrowUpRight } from "lucide-astro";
import { t, type Locale } from "@/lib/i18n";
import { PLATFORM_SERVICES } from "@/lib/site";

type Props = { locale: Locale };
const { locale } = Astro.props;
---
<section class="py-20 sm:py-28" data-reveal>
  <div class="container mx-auto px-6">
    <header class="section-heading">
      <div class="max-w-2xl">
        <p class="section-eyebrow">{t("home.platform.heading", locale)}</p>
        <h2 class="section-title">{t("home.platform.heading", locale)}</h2>
        <p class="section-copy">{t("home.platform.subhead", locale)}</p>
      </div>
    </header>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2" data-motion-section>
      {PLATFORM_SERVICES.map((s) => (
        <GlassCard interactive class="group overflow-hidden p-0 bg-bg-1/40" data-motion-item>
          <a
            href={s.url}
            target="_blank"
            rel="noopener"
            aria-label={s.name}
            class="absolute inset-0 z-10"
          ></a>
          <VisualCardMedia
            seed={s.slug}
            title={s.name}
            subtitle={s.tagline[locale]}
            kind="platform"
            {...(s.coverImage ? { image: s.coverImage } : {})}
            class="min-h-[14rem] rounded-none border-0"
          />
          <div class="relative z-10 p-5 sm:p-6">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-h3 font-semibold tracking-[-0.04em]">{s.name}</h3>
              <ArrowUpRight
                size={18}
                class="text-fg-2 transition-all group-hover:text-fg-0 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
              />
            </div>
            <p class="mt-3 text-fg-1 text-body-sm">{s.tagline[locale]}</p>
            <div class="mt-5 flex flex-wrap gap-1.5">
              {s.tags.map((tag) => (
                <span class="px-2.5 py-0.5 rounded-full text-[11px] text-fg-2 bg-bg-1 border border-white/10">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </GlassCard>
      ))}
    </div>
  </div>
</section>
