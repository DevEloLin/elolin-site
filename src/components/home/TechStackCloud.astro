---
import { t, type Locale } from "@/lib/i18n";
import projects from "@/data/projects.json";
import type { Project } from "@/lib/github";
import { langColor } from "@/lib/languages";
type Props = { locale: Locale };
const { locale } = Astro.props;
const langs = Array.from(new Set((projects as Project[])
  .map((p) => p.language).filter(Boolean) as string[])).sort();
---
<section class="py-20" data-reveal>
  <div class="container mx-auto px-6 rounded-[1.75rem] border border-white/[0.08] bg-white/[0.025] p-6 sm:p-8">
    <p class="section-eyebrow">{t("home.techStack.label", locale)}</p>
    <div class="mt-6 flex flex-wrap gap-2.5">
      {langs.map((l) => (
        <span class="inline-flex items-center gap-2 rounded-full border border-white/[0.1] bg-black/20 px-4 py-2 text-body-sm">
          <span class="inline-block w-2 h-2 rounded-full" style={`background:${langColor(l)}`}></span>
          {l}
        </span>
      ))}
    </div>
  </div>
</section>
