---
import { t, localizePath, type Locale } from "@/lib/i18n";
import projects from "@/data/projects.json";
import type { Project } from "@/lib/github";
import ProjectCard from "@/components/projects/ProjectCard.astro";
import { ArrowRight } from "lucide-astro";
type Props = { locale: Locale };
const { locale } = Astro.props;
const all = projects as Project[];
const flagshipSet = new Set(["evoclaw", "kinmate-site"]);
const sample = all.filter((p) => !flagshipSet.has(p.slug)).slice(0, 6);
const allHref = localizePath("/projects", locale);
---
<section class="py-16">
  <div class="container mx-auto px-6">
    <div class="flex items-baseline justify-between">
      <p class="text-caption text-fg-2 uppercase">{t("home.projectsPreview.label", locale)}</p>
      <a href={allHref} class="text-body-sm text-fg-1 hover:text-fg-0 inline-flex items-center gap-1">
        {t("home.projectsPreview.viewAll", locale)} <ArrowRight size={14} />
      </a>
    </div>
    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sample.map((p) => (
        <ProjectCard project={p} locale={locale} href={`${locale === "zh" ? "/zh" : ""}/projects/${p.slug}`} />
      ))}
    </div>
  </div>
</section>
