---
import { t, localizePath, type Locale } from "@/lib/i18n";
import projects from "@/data/projects.json";
import type { Project } from "@/lib/github";
import ProjectCard from "@/components/projects/ProjectCard.astro";
import { ArrowRight } from "lucide-astro";
type Props = { locale: Locale };
const { locale } = Astro.props;
const all = projects as Project[];
const flagshipSet = new Set(["evoclaw", "kinmate-site"]);
const sample = all.filter((p) => !flagshipSet.has(p.slug)).slice(0, 6);
const allHref = localizePath("/projects", locale);
---
<section class="py-20 sm:py-28" data-reveal>
  <div class="container mx-auto px-6">
    <div class="section-heading mb-0">
      <div>
        <p class="section-eyebrow">{t("home.projectsPreview.label", locale)}</p>
        <h2 class="section-title">{locale === "zh" ? "公开构建。" : "Built in public."}</h2>
      </div>
      <a href={allHref} class="inline-flex items-center gap-1 border-b border-white/[0.14] pb-1 text-body-sm text-fg-1 transition hover:border-blue-200/70 hover:text-fg-0">
        {t("home.projectsPreview.viewAll", locale)} <ArrowRight size={14} />
      </a>
    </div>
    <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3" data-motion-section>
      {sample.map((p) => (
        <ProjectCard project={p} locale={locale} href={`${locale === "zh" ? "/zh" : ""}/projects/${p.slug}`} />
      ))}
    </div>
  </div>
</section>
