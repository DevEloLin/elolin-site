---
import { SITE, type Locale } from "@/lib/site";
type Props = {
  title: string;
  description?: string;
  locale: Locale;
  path: string;
  ogImage?: string;
  keywords?: string[];
};
const { title, description, locale, path, ogImage = "/og-launch.png", keywords } = Astro.props;
const fullTitle = title === SITE.name ? SITE.name : `${title} · ${SITE.name}`;
const desc = description ?? SITE.description[locale];
const canonical = `${SITE.url}${path}`;
const enPart = path.replace(/^\/zh\/?/, "/") || "/";
const zhPart = enPart === "/" ? "/zh/" : `/zh${enPart}`;

// Default keywords — comprehensive EloLin family terms covering parent brand
// + 7 product brands + category positioning + audience + alternatives. The
// same set seeds keywords for every page that doesn't override via prop.
const DEFAULT_KEYWORDS = locale === "zh"
  ? [
      // 品牌父
      "EloLin", "elolin.com", "EloLin 工作室",
      // 7 个产品品牌
      "EvoClaw", "KinMate", "TestHive", "EloGames", "EloLin Accounts", "EloLin Domains", "mv3migrate",
      // 公司定位
      "独立开发者", "一人公司", "独立 SaaS", "indie hacker",
      "一人创业", "副业产品", "全栈独立开发",
      "AI 产品", "AI 应用", "AI 工具",
      // 产品类别
      "本地 AI agent", "AI agent 运行时",
      "家庭健康应用", "私密家庭健康保险库",
      "应用测试者", "Google Play Closed Testing", "12 个测试者 14 天",
      "浏览器游戏", "免费 HTML5 游戏",
      "单点登录", "统一账号 SSO",
      "免费子域名托管", "免费 DNS",
      "Chrome 扩展迁移", "MV2 到 MV3 迁移",
      // 跨产品组合
      "EloLin 全家桶", "EloLin 产品矩阵",
      "EloLin 单点登录", "EloLin 共享账号",
    ]
  : [
      // Parent brand
      "EloLin", "elolin.com", "EloLin studio", "EloLin company",
      // 7 product brands
      "EvoClaw", "KinMate", "TestHive", "EloGames", "EloLin Accounts", "EloLin Domains", "mv3migrate",
      // Founder positioning
      "solo developer", "one-person company", "indie hacker",
      "indie products", "indie SaaS", "indie products company",
      "AI products", "AI applications", "AI tools",
      "one person many products",
      // Product categories
      "local AI agent", "self-evolving AI agent",
      "family health app", "private family health vault",
      "app testing platform", "Google Play Closed Testing", "12 testers 14 days",
      "real human testers", "beta tester marketplace",
      "browser games", "free HTML5 games", "instant play games",
      "single sign-on", "SSO platform", "OAuth identity",
      "free subdomain hosting", "free DNS", "instant DNS",
      "Chrome extension migration", "MV2 to MV3", "Manifest V3 migration",
      // Cross-product family
      "EloLin product family", "EloLin one-account",
      "EloLin SSO", "cross-product sign-in",
      // Audience
      "indie Android developer", "solo founder",
      "Chrome extension developer", "Closed Testing requirement",
      // Brand alternatives
      "elolin", "elo lin", "develolin",
    ];
const kwList = keywords && keywords.length > 0 ? keywords : DEFAULT_KEYWORDS;
---
<title>{fullTitle}</title>
<meta name="description" content={desc} />
<meta name="keywords" content={kwList.join(", ")} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="en" href={`${SITE.url}${enPart}`} />
<link rel="alternate" hreflang="zh" href={`${SITE.url}${zhPart}`} />
<link rel="alternate" hreflang="x-default" href={`${SITE.url}${enPart}`} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={desc} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={`${SITE.url}${ogImage}`} />
<meta property="og:locale" content={locale === "zh" ? "zh_CN" : "en_US"} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@DevEloLin" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="theme-color" content="#0A0A0F" />
