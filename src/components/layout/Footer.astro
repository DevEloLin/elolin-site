---
import EloLogo from "@/components/ui/EloLogo.astro";
import { Github, Twitter, Mail } from "lucide-astro";
import { t, getLocaleFromPath } from "@/lib/i18n";
import { SITE } from "@/lib/site";
const locale = getLocaleFromPath(Astro.url.pathname);
---
<footer class="site-footer">
  <div class="site-footer__line" aria-hidden="true"></div>
  <div class="site-footer__grid">
    <div class="md:col-span-2 space-y-5">
      <div class="flex items-center gap-3 text-fg-0">
        <EloLogo size={24} />
        <span class="font-semibold tracking-[-0.02em]">{t("common.footer.rights", locale)}</span>
      </div>
      <p class="max-w-sm leading-relaxed">{t("common.footer.tagline", locale)}</p>
      <div class="flex items-center gap-2 pt-3">
        <a href={`mailto:${SITE.email}`} aria-label="Email" class="site-footer__social"><Mail size={18} /></a>
        <a href={SITE.github} target="_blank" rel="noopener" aria-label="GitHub" class="site-footer__social"><Github size={18} /></a>
        <a href={SITE.twitter} target="_blank" rel="noopener" aria-label="X" class="site-footer__social"><Twitter size={18} /></a>
      </div>
    </div>
    
    <div>
      <h3 class="site-footer__label">EloLin Ecosystem</h3>
      <ul class="site-footer__links">
        <li><a href="https://testhive.elolin.com" target="_blank" rel="noopener" class="hover:text-fg-0 transition">TestHive</a></li>
        <li><a href="https://kinmate.elolin.com" target="_blank" rel="noopener" class="hover:text-fg-0 transition">KinMate</a></li>
        <li><a href="https://domains.elolin.com" target="_blank" rel="noopener" class="hover:text-fg-0 transition">EloLin Domains</a></li>
        <li><a href="https://games.elolin.com" target="_blank" rel="noopener" class="hover:text-fg-0 transition">EloGames</a></li>
        <li><a href="https://accounts.elolin.com" target="_blank" rel="noopener" class="hover:text-fg-0 transition">EloLin Accounts</a></li>
        <li><a href="https://mv3migrate.elolin.com" target="_blank" rel="noopener" class="hover:text-fg-0 transition">mv3migrate</a></li>
      </ul>
    </div>

    <div>
      <h3 class="site-footer__label">Legal</h3>
      <ul class="site-footer__links">
        <li><a href="https://testhive.elolin.com/en/legal/terms" class="hover:text-fg-0 transition">Terms of Service</a></li>
        <li><a href="https://testhive.elolin.com/en/legal/privacy" class="hover:text-fg-0 transition">Privacy Policy</a></li>
        <li><a href="mailto:support@elolin.com" class="hover:text-fg-0 transition">Contact Support</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer { position: relative; margin-top: 4rem; overflow: hidden; border-top: 1px solid rgba(255,255,255,0.06); background: rgba(3, 4, 8, 0.58); }
  .site-footer__line { position: absolute; top: -1px; left: 8%; width: 18rem; height: 1px; background: linear-gradient(90deg, transparent, rgba(96,165,250,0.8), transparent); }
  .site-footer__grid { display: grid; width: min(100% - 3rem, 76rem); margin: 0 auto; padding: 4.5rem 0; gap: 3.5rem; color: var(--fg-2); font-size: 0.875rem; grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .site-footer__label { margin-bottom: 1.25rem; color: var(--fg-0); font-family: "Geist Mono", monospace; font-size: 0.67rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; }
  .site-footer__links { display: grid; gap: 0.8rem; }
  .site-footer__links a { transition: color 180ms ease; }
  .site-footer__links a:hover { color: var(--fg-0); }
  .site-footer__social { display: grid; width: 2.25rem; height: 2.25rem; place-items: center; border: 1px solid rgba(255,255,255,0.1); border-radius: 9999px; color: var(--fg-1); transition: transform 180ms ease, background 180ms ease, color 180ms ease; }
  .site-footer__social:hover { transform: translateY(-2px); background: rgba(255,255,255,0.08); color: var(--fg-0); }
  @media (max-width: 767px) { .site-footer__grid { width: min(100% - 2rem, 76rem); grid-template-columns: 1fr 1fr; gap: 2.5rem 1.5rem; padding: 3.5rem 0; } .site-footer__grid > :first-child { grid-column: 1 / -1; } }
</style>
