---
import "../../styles/global.css";
import MetaTags from "./MetaTags.astro";
import { type Locale } from "@/lib/site";
import { organization, website } from "@/lib/seo";
type Props = {
  title: string;
  description?: string;
  locale: Locale;
  ogImage?: string;
};
const { title, description, locale, ogImage } = Astro.props;
const path = Astro.url.pathname;
const orgJson = JSON.stringify(organization());
const siteJson = JSON.stringify(website(locale));
---
<!doctype html>
<html lang={locale === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preload" href="/fonts/Geist-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Geist-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <MetaTags
      {title}
      {locale}
      {path}
      {...(description !== undefined ? { description } : {})}
      {...(ogImage !== undefined ? { ogImage } : {})}
    />
    {/* Sitewide JSON-LD · Organization + WebSite (the brand entity graph that
        every EloLin sub-product references via @id="https://elolin.com/#org") */}
    <script type="application/ld+json" set:html={orgJson} />
    <script type="application/ld+json" set:html={siteJson} />
    {/* Google AdSense · 仅 verify 站点所有权所需 · 主站不放广告位 ·
        publisher ID 与 testhive / domains 子站共用 ca-pub-3142706921372874 */}
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3142706921372874"
      crossorigin="anonymous"
    ></script>
    <slot name="head" />
  </head>
  <body class="bg-bg-0 text-fg-0 font-sans antialiased min-h-screen flex flex-col">
    <slot name="header" />
    <div class="flex-1">
      <slot />
    </div>
    <slot name="footer" />
    <script>
      import { setupReveal } from "@/lib/motion";
      if (document.readyState === "complete") setupReveal();
      else window.addEventListener("DOMContentLoaded", () => setupReveal());
    </script>
  </body>
</html>
