---
import EloLogo from "@/components/ui/EloLogo.astro";
import LangSwitch from "@/components/ui/LangSwitch.astro";
import { t, getLocaleFromPath, localizePath } from "@/lib/i18n";
import { Github } from "lucide-astro";
import { SITE } from "@/lib/site";
const path = Astro.url.pathname;
const locale = getLocaleFromPath(path);
const nav = [
  { href: localizePath("/products", locale), key: "common.nav.products" },
  { href: localizePath("/projects", locale), key: "common.nav.projects" },
  { href: localizePath("/about",   locale), key: "common.nav.about" },
  { href: localizePath("/contact", locale), key: "common.nav.contact" },
];
const homeHref = localizePath("/", locale);
---
<header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-300 ease-out">
  <div class="site-header__bar">
    <a href={homeHref} class="flex items-center gap-2.5">
      <EloLogo size={28} />
      <span class="text-body font-semibold tracking-[-0.03em]">EloLin</span>
    </a>
    <nav class="hidden md:flex items-center gap-1 rounded-full border border-white/[0.08] bg-white/[0.035] p-1" aria-label="Primary navigation">
      {nav.map((n) => (
        <a href={n.href} class="rounded-full px-3.5 py-1.5 text-body-sm text-fg-1 transition hover:bg-white/[0.08] hover:text-fg-0">
          {t(n.key, locale)}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-1 rounded-full border border-white/[0.08] bg-white/[0.035] p-1">
      <LangSwitch current={locale} {path} />
      <a href={SITE.github} target="_blank" rel="noopener"
         class="p-2 text-fg-1 hover:text-fg-0 rounded-md hover:bg-bg-1 transition"
         aria-label="GitHub">
        <Github size={18} />
      </a>
    </div>
  </div>
</header>

<style>
  .site-header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: min(100% - 2rem, 76rem);
    height: 4.75rem;
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .site-header__bar { width: min(100% - 1.25rem, 76rem); height: 4.25rem; }
  }
</style>

<script>
  const h = document.getElementById("site-header");
  if (h) {
    const onScroll = () => {
      if (window.scrollY > 8) {
        h.classList.add("bg-bg-0/70", "backdrop-blur-xl", "border-b", "border-white/10");
      } else {
        h.classList.remove("bg-bg-0/70", "backdrop-blur-xl", "border-b", "border-white/10");
      }
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
