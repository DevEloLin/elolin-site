---
import Layout from "@/components/layout/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import ProductCard from "@/components/products/ProductCard.astro";
import PageIntro from "@/components/ui/PageIntro.astro";
import PlatformServices from "@/components/home/PlatformServices.astro";
import JsonLd from "@/components/seo/JsonLd.astro";
import { FLAGSHIP_PRODUCTS } from "@/lib/site";
import {
  ELOLIN_CATALOG,
  breadcrumb,
  productItemList,
  softwareApplication,
} from "@/lib/seo";
import { t } from "@/lib/i18n";

const locale = "en" as const;
---
<Layout title={t("products.title", locale)} locale={locale}>
  <JsonLd slot="head" data={productItemList(ELOLIN_CATALOG, locale, "https://elolin.com/")} />
  {ELOLIN_CATALOG.map((p) => (
    <JsonLd slot="head" data={softwareApplication(p, locale)} />
  ))}
  <JsonLd
    slot="head"
    data={breadcrumb([
      { name: "Home", url: "https://elolin.com/" },
      { name: "Products", url: "https://elolin.com/products" },
    ])}
  />
  <Header slot="header" />
  <main class="page-shell">
    <PageIntro eyebrow="The suite" title={t("products.title", locale)} description={t("products.subtitle", locale)} index="02 / 04" meta={`${FLAGSHIP_PRODUCTS.length} live products`} />
    <div class="mt-14 grid grid-cols-1 lg:grid-cols-2 gap-6">
      {FLAGSHIP_PRODUCTS.map((p) => (
        <ProductCard product={p} {locale} />
      ))}
      <div class="relative flex min-h-[24rem] items-center justify-center overflow-hidden rounded-[1.5rem] border border-dashed border-blue-200/20 bg-[radial-gradient(circle_at_50%_20%,rgba(59,130,246,0.13),transparent_42%),rgba(255,255,255,0.025)] p-8 text-center text-fg-2">
        <div>
          <p class="section-eyebrow justify-center">{t("products.comingNext", locale)}</p>
          <p class="mt-3 text-body-lg text-fg-1 max-w-sm">
            More products are designed as image-first cards and will slot into this grid.
          </p>
        </div>
      </div>
    </div>
  </main>
  <PlatformServices {locale} />
  <Footer slot="footer" />
</Layout>
