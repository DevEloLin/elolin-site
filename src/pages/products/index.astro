---
import Layout from "@/components/layout/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import ProductCard from "@/components/products/ProductCard.astro";
import PlatformServices from "@/components/home/PlatformServices.astro";
import JsonLd from "@/components/seo/JsonLd.astro";
import { FLAGSHIP_PRODUCTS } from "@/lib/site";
import {
  ELOLIN_CATALOG,
  breadcrumb,
  productItemList,
  softwareApplication,
} from "@/lib/seo";
import { t } from "@/lib/i18n";

const locale = "en" as const;
---
<Layout title={t("products.title", locale)} locale={locale}>
  <JsonLd slot="head" data={productItemList(ELOLIN_CATALOG, locale, "https://elolin.com/")} />
  {ELOLIN_CATALOG.map((p) => (
    <JsonLd slot="head" data={softwareApplication(p, locale)} />
  ))}
  <JsonLd
    slot="head"
    data={breadcrumb([
      { name: "Home", url: "https://elolin.com/" },
      { name: "Products", url: "https://elolin.com/products" },
    ])}
  />
  <Header slot="header" />
  <main class="pt-32 pb-24 container mx-auto px-6 max-w-4xl">
    <h1 class="text-display-2 font-semibold">{t("products.title", locale)}</h1>
    <p class="mt-4 text-fg-1 text-body-lg">{t("products.subtitle", locale)}</p>
    <div class="mt-12 space-y-8">
      {FLAGSHIP_PRODUCTS.map((p) => (
        <ProductCard product={p} {locale} />
      ))}
      <div class="rounded-2xl border border-dashed border-white/10 p-8 text-center text-fg-2">
        {t("products.comingNext", locale)}…
      </div>
    </div>
  </main>
  <PlatformServices {locale} />
  <Footer slot="footer" />
</Layout>
