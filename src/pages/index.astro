---
import Layout from "@/components/layout/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Hero from "@/components/home/Hero.astro";
import FlagshipProducts from "@/components/home/FlagshipProducts.astro";
import PlatformServices from "@/components/home/PlatformServices.astro";
import ProjectsPreview from "@/components/home/ProjectsPreview.astro";
import TechStackCloud from "@/components/home/TechStackCloud.astro";
import Manifesto from "@/components/home/Manifesto.astro";
import Faq from "@/components/home/Faq.astro";
import JsonLd from "@/components/seo/JsonLd.astro";
import { t } from "@/lib/i18n";
import { ELOLIN_CATALOG, breadcrumb, howTo, productItemList, softwareApplication } from "@/lib/seo";
const locale = "en" as const;

const SHIP_SOLO_STEPS = [
  { name: "One person · many products", text: "EloLin is operated by Wei Li alone. Eight live products (EvoClaw · PhotoAI · KinMate · TestHive · EloGames · Zivoe · Domains · mv3migrate) without a team, without external investors, without enterprise process." },
  { name: "Shared identity", text: "Every SaaS product reuses EloLin Accounts SSO. One sign-in unlocks the entire family. Saves duplicate auth code across products and gives users seamless cross-product flow." },
  { name: "Shared platform services", text: "Sub-domain hosting (EloLin Domains) and the games CDN are shared infrastructure. New products plug into the existing platform instead of rebuilding identity / DNS / billing each time." },
  { name: "Boring stack on purpose", text: "Same stack across products (Next.js · Astro · Supabase · Cloudflare). Lets one person debug any product end-to-end without switching mental models." },
  { name: "Ship early · iterate publicly", text: "Every product is launched even when small. Open-source where possible (github.com/DevEloLin). Feedback drives the next product in the line-up." },
];
---
<Layout title={t("home.hero.title", locale)} locale={locale}>
  <JsonLd slot="head" data={breadcrumb([{ name: "Home", url: "https://elolin.com/" }])} />
  <JsonLd slot="head" data={productItemList(ELOLIN_CATALOG, locale, "https://elolin.com/")} />
  <JsonLd slot="head" data={howTo("How EloLin ships eight products solo", "Five operating principles that let a single developer maintain and ship an eight-product family.", SHIP_SOLO_STEPS)} />
  {ELOLIN_CATALOG.map((p) => (
    <JsonLd slot="head" data={softwareApplication(p, locale)} />
  ))}
  <Header slot="header" />
  <Hero {locale} />
  <FlagshipProducts {locale} />
  <PlatformServices {locale} />
  <ProjectsPreview {locale} />
  <TechStackCloud {locale} />
  <Faq {locale} />
  <Manifesto {locale} />
  <Footer slot="footer" />
</Layout>
