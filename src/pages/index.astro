---
import Layout from "@/components/layout/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Hero from "@/components/home/Hero.astro";
import FlagshipProducts from "@/components/home/FlagshipProducts.astro";
import PlatformServices from "@/components/home/PlatformServices.astro";
import ProjectsPreview from "@/components/home/ProjectsPreview.astro";
import TechStackCloud from "@/components/home/TechStackCloud.astro";
import Manifesto from "@/components/home/Manifesto.astro";
import JsonLd from "@/components/seo/JsonLd.astro";
import { t } from "@/lib/i18n";
import { ELOLIN_CATALOG, productItemList, softwareApplication } from "@/lib/seo";
const locale = "en" as const;
---
<Layout title={t("home.hero.title", locale)} locale={locale}>
  <JsonLd slot="head" data={productItemList(ELOLIN_CATALOG, locale, "https://elolin.com/")} />
  {ELOLIN_CATALOG.map((p) => (
    <JsonLd slot="head" data={softwareApplication(p, locale)} />
  ))}
  <Header slot="header" />
  <Hero {locale} />
  <FlagshipProducts {locale} />
  <PlatformServices {locale} />
  <ProjectsPreview {locale} />
  <TechStackCloud {locale} />
  <Manifesto {locale} />
  <Footer slot="footer" />
</Layout>
