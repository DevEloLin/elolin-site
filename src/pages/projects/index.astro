---
import Layout from "@/components/layout/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import CategoryChips from "@/components/projects/CategoryChips.astro";
import PageIntro from "@/components/ui/PageIntro.astro";
import ProjectGrid from "@/components/projects/ProjectGrid.astro";
import projects from "@/data/projects.json";
import type { Project } from "@/lib/github";
import { t } from "@/lib/i18n";
const locale = "en" as const;
const all = projects as Project[];
---
<Layout title={t("projects.title", locale)} locale={locale}>
  <Header slot="header" />
  <main class="page-shell">
    <PageIntro eyebrow="Built in public" title={t("projects.title", locale)} description={t("projects.subtitle", locale)} index="03 / 04" meta={`${all.length} repositories`} />
    <div class="mt-12"><CategoryChips locale={locale} active="all" /></div>
    <ProjectGrid projects={all} {locale} />
  </main>
  <Footer slot="footer" />
</Layout>
