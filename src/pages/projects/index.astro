---
import Layout from "@/components/layout/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import CategoryChips from "@/components/projects/CategoryChips.astro";
import ProjectGrid from "@/components/projects/ProjectGrid.astro";
import projects from "@/data/projects.json";
import type { Project } from "@/lib/github";
import { t } from "@/lib/i18n";
const locale = "en" as const;
const all = projects as Project[];
---
<Layout title={t("projects.title", locale)} locale={locale}>
  <Header slot="header" />
  <main class="pt-28 pb-24 container mx-auto px-6 max-w-7xl">
    <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
      <div class="max-w-3xl">
        <p class="text-caption text-fg-2 uppercase">{t("projects.title", locale)}</p>
        <h1 class="mt-4 text-display-2 font-semibold">{t("projects.title", locale)}</h1>
        <p class="mt-4 text-fg-1 text-body-lg">{t("projects.subtitle", locale)}</p>
      </div>
      <span class="text-caption text-fg-2 uppercase">{all.length} repos</span>
    </div>
    <div class="mt-10"><CategoryChips locale={locale} active="all" /></div>
    <ProjectGrid projects={all} {locale} />
  </main>
  <Footer slot="footer" />
</Layout>
