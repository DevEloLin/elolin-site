---
import Layout from "@/components/layout/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import ContactCard from "@/components/contact/ContactCard.astro";
import VisualCardMedia from "@/components/ui/VisualCardMedia.astro";
import { Mail, Github, Twitter } from "lucide-astro";
import { SITE } from "@/lib/site";
import { t } from "@/lib/i18n";

const locale = "zh" as const;
---
<Layout title={t("contact.title", locale)} locale={locale}>
  <Header slot="header" />
  <main class="pt-28 pb-24 container mx-auto px-6 max-w-7xl">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <VisualCardMedia
        seed="contact-zh"
        title={t("contact.title", locale)}
        subtitle={t("contact.subtitle", locale)}
        kind="platform"
        image="https://elolin.com/og-default.png"
        class="min-h-[22rem] rounded-[1.75rem]"
      />
      <div>
        <p class="text-caption text-fg-2 uppercase">{t("contact.title", locale)}</p>
        <h1 class="mt-4 text-display-2 font-semibold">{t("contact.title", locale)}</h1>
        <p class="mt-4 text-fg-1 text-body-lg max-w-xl">{t("contact.subtitle", locale)}</p>
        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
          <ContactCard icon={Mail} label={t("contact.channels.email.label", locale)} value={SITE.email} href={`mailto:${SITE.email}`} copy />
          <ContactCard icon={Github} label={t("contact.channels.github.label", locale)} value="@DevEloLin" href={SITE.github} />
          <ContactCard icon={Twitter} label={t("contact.channels.twitter.label", locale)} value="@DevEloLin" href={SITE.twitter} />
        </div>
        <p class="mt-8 text-fg-2 text-body-sm">{t("contact.response", locale)}</p>
      </div>
    </div>
  </main>
  <Footer slot="footer" />
</Layout>
