---
import Layout from "@/components/layout/Layout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Hero from "@/components/home/Hero.astro";
import FlagshipProducts from "@/components/home/FlagshipProducts.astro";
import PlatformServices from "@/components/home/PlatformServices.astro";
import ProjectsPreview from "@/components/home/ProjectsPreview.astro";
import TechStackCloud from "@/components/home/TechStackCloud.astro";
import Manifesto from "@/components/home/Manifesto.astro";
import Faq from "@/components/home/Faq.astro";
import JsonLd from "@/components/seo/JsonLd.astro";
import { t } from "@/lib/i18n";
import { ELOLIN_CATALOG, breadcrumb, howTo, productItemList, softwareApplication } from "@/lib/seo";
const locale = "zh" as const;

const SHIP_SOLO_STEPS_ZH = [
  { name: "一人 · 多产品", text: "EloLin 由 Wei Li 一人运营。同时在线 7 个产品(EvoClaw / KinMate / TestHive / EloGames / Accounts / Domains / mv3migrate)· 没团队 · 没外部投资 · 没企业流程。" },
  { name: "共享身份", text: "所有 SaaS 产品复用 EloLin Accounts 单点登录。一次登录通行全家族 · 省去每个产品重复造 auth 代码 · 用户跨产品体验顺滑。" },
  { name: "共享平台服务", text: "子域名托管(EloLin Domains)和游戏 CDN 是共享基础设施。新产品接入现有平台 · 不必重造 identity / DNS / billing。" },
  { name: "刻意用无聊技术栈", text: "所有产品同栈(Next.js · Astro · Supabase · Cloudflare)。一个人能从头到尾 debug 任何产品 · 不必切换心智模型。" },
  { name: "尽早上线 · 公开迭代", text: "产品再小也上线。能开源就开源(github.com/DevEloLin)· 用户反馈驱动下一个产品。" },
];
---
<Layout title={t("home.hero.title", locale)} locale={locale}>
  <JsonLd slot="head" data={breadcrumb([{ name: "首页", url: "https://elolin.com/zh/" }])} />
  <JsonLd slot="head" data={productItemList(ELOLIN_CATALOG, locale, "https://elolin.com/zh/")} />
  <JsonLd slot="head" data={howTo("EloLin 一人维护 7 个产品的运营方法", "让一个开发者同时维护和发布七个产品的五条原则。", SHIP_SOLO_STEPS_ZH)} />
  {ELOLIN_CATALOG.map((p) => (
    <JsonLd slot="head" data={softwareApplication(p, locale)} />
  ))}
  <Header slot="header" />
  <Hero {locale} />
  <FlagshipProducts {locale} />
  <PlatformServices {locale} />
  <ProjectsPreview {locale} />
  <TechStackCloud {locale} />
  <Faq {locale} />
  <Manifesto {locale} />
  <Footer slot="footer" />
</Layout>
